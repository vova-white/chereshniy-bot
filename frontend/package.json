    "jsdom": "^29.1.1",
    "npm-run-all2": "^8.0.4",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "~6.0.3",
    "vite": "npm:@voidzero-dev/vite-plus-core@^0.1.21",
    "vite-plugin-vue-devtools": "^8.1.2",
    "vite-plus": "catalog:",
    "vitest": "npm:@voidzero-dev/vite-plus-test@^0.1.21",
    "vue-tsc": "^3.2.9"
